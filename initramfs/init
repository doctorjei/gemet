#!/bin/sh
#
# tenkei init — mount virtiofs rootfs and switch_root into it
#
# This is the /init script inside the initramfs. It expects the host to
# serve the container rootfs via virtiofsd with the tag "rootfs".
#

mount -t devtmpfs devtmpfs /dev
mount -t proc proc /proc
mount -t sysfs sysfs /sys

mkdir -p /newroot
mount -t virtiofs rootfs /newroot

exec switch_root /newroot /sbin/init
