#!/bin/sh
#
# tenkei init — mount rootfs (virtiofs or block device) and switch_root
#
# This is the /init script inside the initramfs. Dispatches on kernel
# cmdline:
#
#   root=rootfs rootfstype=virtiofs       → virtiofs mount (tag=rootfs),
#                                            dax=inode if the host + kernel
#                                            support it; graceful fallback
#                                            otherwise (mount is retried
#                                            without dax=inode).
#   root=/dev/<dev> rootfstype=<fs>       → block-device mount (e.g. qcow2
#                                            disk-image boot). ext4 is the
#                                            expected fs for Yggdrasil's
#                                            qcow2 artifact form.
#   (unset / anything else)               → defaults to virtiofs (tag=rootfs)
#                                            for back-compat with kento.
#   init=<path>                           → kernel-standard override for the
#                                            program exec'd after switch_root
#                                            (e.g. init=/bin/bash for rescue).
#                                            Defaults to /sbin/init.
#
# On any mount failure, drops to an emergency /bin/sh.
#

mount -t devtmpfs devtmpfs /dev
mount -t proc proc /proc
mount -t sysfs sysfs /sys

# Parse root=, rootfstype=, and init= from /proc/cmdline.
# init= honors the kernel-standard override (e.g. init=/bin/bash for
# rescue, init=/some-diag for bring-up probes). Silently ignoring it
# would surprise downstream consumers that rely on it.
ROOT=""
ROOTFSTYPE=""
INIT=""
for arg in $(cat /proc/cmdline); do
	case "$arg" in
		root=*)       ROOT="${arg#root=}" ;;
		rootfstype=*) ROOTFSTYPE="${arg#rootfstype=}" ;;
		init=*)       INIT="${arg#init=}" ;;
	esac
done

# Defaults preserve kento's current contract: virtiofs with tag=rootfs.
[ -z "$ROOT" ]       && ROOT="rootfs"
[ -z "$ROOTFSTYPE" ] && ROOTFSTYPE="virtiofs"
[ -z "$INIT" ]       && INIT="/sbin/init"

mkdir -p /newroot

mount_ok=0
case "$ROOTFSTYPE" in
	virtiofs)
		if mount -t virtiofs "$ROOT" /newroot -o dax=inode 2>/dev/null; then
			mount_ok=1
		elif mount -t virtiofs "$ROOT" /newroot; then
			mount_ok=1
		fi
		;;
	*)
		if mount -t "$ROOTFSTYPE" "$ROOT" /newroot; then
			mount_ok=1
		fi
		;;
esac

if [ "$mount_ok" -ne 1 ]; then
	echo "tenkei: rootfs mount failed (root=$ROOT fstype=$ROOTFSTYPE)."
	echo "tenkei: check kernel cmdline root= and rootfstype= values."
	echo "tenkei: for virtiofs, the tag must match the QEMU -device tag= arg."
	echo "tenkei: for rescue, append init=/bin/sh to the kernel cmdline."
	echo "Dropping to emergency shell."
	exec /bin/sh
fi

# Move initramfs-mounted pseudo-filesystems into the new root before
# switch_root. Without this, /dev in the new root is empty and
# init=/bin/bash (and, less reliably, systemd) deadlocks silently.
move_failed=""
mount --move /dev  /newroot/dev  || move_failed=/dev
mount --move /proc /newroot/proc || move_failed=/proc
mount --move /sys  /newroot/sys  || move_failed=/sys

if [ -n "$move_failed" ]; then
	echo "tenkei: mount --move $move_failed -> /newroot$move_failed failed."
	echo "tenkei: pseudo-fs won't be populated in the new root; init would hang."
	echo "tenkei: check that /newroot$move_failed exists on the rootfs."
	echo "Dropping to emergency shell."
	exec /bin/sh
fi

echo "tenkei: mounted $ROOT as $ROOTFSTYPE; switching root to $INIT."

# -c /dev/console reopens stdin/stdout/stderr on the new root's
# /dev/console so kernel messages keep flowing after chroot.
exec switch_root -c /dev/console /newroot "$INIT"

# switch_root is meant to exec $INIT and never return. If we got here, it
# failed to exec — most often because $INIT is missing or not executable
# inside the rootfs.
echo "tenkei: switch_root failed (init=$INIT on /newroot)."
echo "tenkei: check that $INIT exists and is executable inside the rootfs."
echo "tenkei: for rescue, append init=/bin/sh to the kernel cmdline."
echo "Dropping to emergency shell."
exec /bin/sh
